# LifeOS Agent backend
LIFEOS_AGENT_PORT=4399

# Text LLM node, OpenAI-compatible chat completions.
# Use a real value only in .env, never in committed files.
LIFEOS_LLM_ENABLED=true
LIFEOS_LLM_PROVIDER=deepseek
LIFEOS_LLM_BASE_URL=https://api.deepseek.com
LIFEOS_LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=replace-with-your-local-key

# Vision node placeholder for later multimodal memory import.
DOUBAO_VISION_ENDPOINT_ID=replace-with-your-endpoint-id
DOUBAO_API_KEY=replace-with-your-local-key
